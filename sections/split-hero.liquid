<section class="split-hero">
  <div class="split-hero-wrapper">
    <div class="hero-content">
      <span class="hero-subtitle">
        {{ section.settings.subtitle }}
      </span>

      <h1>{{ section.settings.heading }}</h1>

      <p>{{ section.settings.description }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="hero-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="hero-image">
      {% if section.settings.hero_image %}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1500 }}"
          alt="{{ section.settings.heading }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
        >
      {% endif %}
    </div>
  </div>
</section>

<style>
  .split-hero {
    width: 100%;
  }

  .split-hero-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 700px;
  }

  .hero-content {
    background: #edf1ed;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 60px;
  }

  .hero-subtitle {
    color: #6a8471;
    margin-bottom: 0px;
    font-size: 24px;
    font-weight: 700;
  }

  .hero-content h1 {
    font-size: 56px;
    line-height: 1.2;
    max-width: 500px;
    margin-bottom: 20px;
  }

  .hero-content p {
    max-width: 450px;
    color: #777;
    margin-bottom: 30px;
  }

  .hero-btn {
    display: inline-block;
    padding: 14px 35px;
    background: black;
    color: white;
    text-decoration: none;
    border-radius: 12px;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 768px) {
    .split-hero-wrapper {
      grid-template-columns: 1fr;
    }

    .hero-content {
      order: 2;
    }

    .hero-image {
      order: 1;
      min-height: 400px;
    }

    .hero-content h1 {
      font-size: 38px;
    }
  }
</style>

{% schema %}
{
  "name": "Split Hero",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Perfect Skincare"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Care for Your Skin, Care for Your Beauty"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Made using clean, non-toxic ingredients."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Split Hero"
    }
  ]
}
{% endschema %}
